# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-build-home/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.factory

# pm2 deployment
ecosystem.config.cjs

# startup / update scripts
start-pi-web-proxy.sh
update-pi-web.sh

# runtime logs and ephemeral Studio session bindings (never commit)
logs/
.ypi/.runtime/

# Studio task runtime event logs (large, never commit)
.ypi/tasks/**/events.jsonl

# work handoff / task notes (not project code)
handoff/

# .pi/ contains shared agent definitions, skills, and extensions (tracked)
.idea/
