{
  "schemaVersion": 1,
  "id": "ui-change",
  "name": "UI 改动",
  "description": "强调 UI 设计、交互状态和视觉一致性的界面改动流程。",
  "triggers": {
    "slash": [
      "studio-ui"
    ],
    "natural": [
      "让 UI 设计员",
      "走 UI 流程",
      "用工作室设计界面"
    ]
  },
  "initialStatus": "intake",
  "terminalStatuses": [
    "completed",
    "cancelled",
    "archived"
  ],
  "states": {
    "intake": {
      "id": "intake",
      "label": "接单",
      "owner": "architect",
      "progress": 10,
      "instruction": "理解目标、范围、约束和已有材料；需求不清楚时先问问题。",
      "requiredArtifacts": [
        "brief.md"
      ],
      "optionalArtifacts": [],
      "requiresSubagent": true
    },
    "planning": {
      "id": "planning",
      "label": "UI + 技术设计",
      "owner": "architect",
      "progress": 35,
      "instruction": "架构师产出技术计划和 plan-review.md 计划审批书，并必须派发 UI 设计员基于现有项目产出 HTML 原型；计划审批书应链接 ui.md 与 HTML 原型；ui.md 可承载原型或链接，但不能用纯 Markdown 替代。",
      "requiredArtifacts": [
        "plan-review.md",
        "prd.md",
        "ui.md",
        "design.md",
        "implement.md",
        "checks.md"
      ],
      "optionalArtifacts": [],
      "requiresSubagent": true
    },
    "awaiting_approval": {
      "id": "awaiting_approval",
      "label": "等待确认",
      "owner": "main",
      "progress": 45,
      "instruction": "等待用户确认 plan-review.md 计划审批书、方案和 HTML 原型。计划审批书应链接 ui.md 与 HTML 原型；未确认前禁止进入实现阶段。",
      "requiredArtifacts": [
        "plan-review.md",
        "prd.md",
        "ui.md",
        "design.md",
        "implement.md",
        "checks.md"
      ],
      "optionalArtifacts": [],
      "requiresUserApproval": true
    },
    "implementing": {
      "id": "implementing",
      "label": "制作",
      "owner": "implementer",
      "progress": 70,
      "instruction": "主 session 必须通过 ypi_studio_subagent 指派实现员完成实现。",
      "requiredArtifacts": [
        "handoff.md"
      ],
      "optionalArtifacts": [],
      "requiresSubagent": true
    },
    "checking": {
      "id": "checking",
      "label": "检查",
      "owner": "checker",
      "progress": 90,
      "instruction": "主 session 必须通过 ypi_studio_subagent 指派检查员审查 diff、运行验证并修复低风险小问题。",
      "requiredArtifacts": [
        "review.md"
      ],
      "optionalArtifacts": [],
      "requiresSubagent": true
    },
    "changes_requested": {
      "id": "changes_requested",
      "label": "请求修改",
      "owner": "main",
      "progress": 78,
      "instruction": "检查未通过。主 session 需要决定退回实现员修复，还是退回架构师重新设计。",
      "requiredArtifacts": [],
      "optionalArtifacts": []
    },
    "ready": {
      "id": "ready",
      "label": "待收尾",
      "owner": "main",
      "progress": 95,
      "instruction": "检查通过，等待主 session 汇总、提交计划或收尾。",
      "requiredArtifacts": [],
      "optionalArtifacts": []
    },
    "review": {
      "id": "review",
      "label": "审核",
      "owner": "main",
      "progress": 95,
      "instruction": "检查通过，等待主 session 请求用户验收。",
      "requiredArtifacts": [],
      "optionalArtifacts": []
    },
    "user_acceptance": {
      "id": "user_acceptance",
      "label": "用户验收",
      "owner": "main",
      "progress": 97,
      "instruction": "等待用户确认验收。无问题则完成；有问题则创建改进项进入等待改进完成。",
      "requiredArtifacts": [],
      "optionalArtifacts": [],
      "requiresUserApproval": true
    },
    "waiting_for_improvements": {
      "id": "waiting_for_improvements",
      "label": "等待改进完成",
      "owner": "main",
      "progress": 96,
      "instruction": "改进项处理中，全部完成后返回 review 再次请求用户验收。",
      "requiredArtifacts": [],
      "optionalArtifacts": []
    },
    "completed": {
      "id": "completed",
      "label": "完成",
      "owner": "main",
      "progress": 100,
      "instruction": "任务已完成。",
      "requiredArtifacts": [],
      "optionalArtifacts": []
    },
    "blocked": {
      "id": "blocked",
      "label": "阻塞",
      "owner": "main",
      "progress": 50,
      "instruction": "等待用户、外部条件或设计决策。",
      "requiredArtifacts": [],
      "optionalArtifacts": []
    },
    "cancelled": {
      "id": "cancelled",
      "label": "取消",
      "owner": "main",
      "progress": 100,
      "instruction": "任务已取消。",
      "requiredArtifacts": [],
      "optionalArtifacts": []
    },
    "archived": {
      "id": "archived",
      "label": "归档",
      "owner": "main",
      "progress": 100,
      "instruction": "任务已归档。",
      "requiredArtifacts": [],
      "optionalArtifacts": []
    }
  },
  "transitions": [
    {
      "from": "intake",
      "to": "planning"
    },
    {
      "from": "planning",
      "to": "awaiting_approval"
    },
    {
      "from": "awaiting_approval",
      "to": "implementing",
      "requiresUserApproval": true
    },
    {
      "from": "implementing",
      "to": "checking"
    },
    {
      "from": "checking",
      "to": "ready"
    },
    {
      "from": "checking",
      "to": "changes_requested"
    },
    {
      "from": "changes_requested",
      "to": "implementing"
    },
    {
      "from": "changes_requested",
      "to": "planning"
    },
    {
      "from": "ready",
      "to": "completed"
    },
    {
      "from": "checking",
      "to": "review"
    },
    {
      "from": "review",
      "to": "user_acceptance"
    },
    {
      "from": "user_acceptance",
      "to": "completed",
      "requiresUserApproval": true
    },
    {
      "from": "user_acceptance",
      "to": "waiting_for_improvements"
    },
    {
      "from": "waiting_for_improvements",
      "to": "review"
    },
    {
      "from": "intake",
      "to": "blocked",
      "overrideAllowed": true
    },
    {
      "from": "planning",
      "to": "blocked",
      "overrideAllowed": true
    },
    {
      "from": "implementing",
      "to": "blocked",
      "overrideAllowed": true
    },
    {
      "from": "checking",
      "to": "blocked",
      "overrideAllowed": true
    },
    {
      "from": "waiting_for_improvements",
      "to": "blocked",
      "overrideAllowed": true
    },
    {
      "from": "blocked",
      "to": "intake",
      "overrideAllowed": true
    },
    {
      "from": "blocked",
      "to": "planning",
      "overrideAllowed": true
    },
    {
      "from": "blocked",
      "to": "implementing",
      "overrideAllowed": true
    },
    {
      "from": "blocked",
      "to": "waiting_for_improvements",
      "overrideAllowed": true
    },
    {
      "from": "intake",
      "to": "cancelled",
      "overrideAllowed": true
    },
    {
      "from": "planning",
      "to": "cancelled",
      "overrideAllowed": true
    },
    {
      "from": "awaiting_approval",
      "to": "cancelled",
      "overrideAllowed": true
    },
    {
      "from": "waiting_for_improvements",
      "to": "cancelled",
      "overrideAllowed": true
    },
    {
      "from": "completed",
      "to": "archived"
    }
  ]
}
