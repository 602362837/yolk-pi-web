+function getRetryDelayMs(attempt: number, policy: RetryPolicy, retryAfterMs?: number) {
+  if (typeof retryAfterMs === "number") {
+    return Math.max(0, Math.min(retryAfterMs, policy.retryAfterCapMs));
+  }
+  const base = Math.min(policy.baseDelayMs * (2 ** attempt), policy.maxDelayMs);
+  const jitter = policy.jitterMs > 0 ? Math.floor(Math.random() * policy.jitterMs) : 0;
   return base + jitter;
+}
