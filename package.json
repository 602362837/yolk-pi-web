{
  "name": "@alan-zhao/yolk-pi-web",
  "version": "0.7.16",
  "description": "yolk pi web WebChat workspace for the pi coding agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/602362837/pi-agnet-web.git"
  },
  "bugs": {
    "url": "https://github.com/602362837/pi-agnet-web/issues"
  },
  "homepage": "https://github.com/602362837/pi-agnet-web#readme",
  "keywords": [
    "pi",
    "coding-agent",
    "webchat",
    "agent",
    "nextjs"
  ],
  "bin": {
    "ypi": "bin/pi-web.js",
    "ypic": "bin/ypic.js"
  },
  "files": [
    "bin",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "scripts",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 30141",
    "build": "node scripts/build-next.js",
    "start": "next start -p 30141",
    "lint": "eslint .",
    "test:studio-policy": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-ypi-studio-policy.mjs",
    "test:studio-dag": "node --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-ypi-studio-dag.mjs",
    "test:studio-session-ownership": "node --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-ypi-studio-session-ownership.mjs",
    "test:studio-sdk-runner": "node --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-ypi-studio-sdk-runner.mjs",
    "test:session-title": "node --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-session-title.mjs",
    "test:ypic-cli": "node scripts/test-ypic-cli.mjs",
    "test:memory-diagnostics": "node --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-memory-diagnostics.mjs",
    "test:terminal-ssh": "node scripts/test-terminal-ssh-config.mjs",
    "test:opencode-go-failover-detect": "npx tsx lib/opencode-go-account-failover.test.ts",
    "test:opencode-go-failover-behavior": "node scripts/test-opencode-go-failover-behavior.mjs",
    "test:chatgpt-failover-contract": "node scripts/test-chatgpt-failover-contract.mjs",
    "test:grok-global-auth": "node scripts/test-grok-global-auth.mjs",
    "test:grok-failover-adapter": "node scripts/test-grok-failover-adapter.mjs",
    "test:grok-failover-runtime": "node scripts/test-grok-failover-runtime.mjs",
    "test:grok-quota": "node scripts/test-grok-quota.mjs",
    "test:grok-provider": "node scripts/test-grok-provider.mjs",
    "test:grok-accounts": "node scripts/test-grok-accounts.mjs",
    "test:grok-all": "npm run test:grok-provider && npm run test:grok-accounts && npm run test:grok-quota && npm run test:grok-session-isolation && npm run test:oauth-accounts && npm run test:grok-global-auth && npm run test:grok-failover-adapter && npm run test:grok-failover-runtime",
    "test:api-key-accounts": "node scripts/run-api-key-accounts-test.mjs",
    "test:oauth-accounts": "node scripts/run-oauth-account-tests.mjs",
    "test:grok-session-isolation": "npx tsx lib/grok-session-isolation.test.ts",
    "test:usage-rollup": "node --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-usage-stats-rollup.mjs",
    "test:llm-usage-store": "node --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-llm-usage-store.mjs",
    "test:session-metadata": "node --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-session-metadata-scanner.mjs",
    "test:session-list-performance": "node --expose-gc --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-session-list-performance.mjs",
    "test:model-prices": "node --loader ./scripts/ts-extension-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-model-prices.mjs",
    "prepublishOnly": "npm run lint && tsc --noEmit && npm run build",
    "release:patch": "npm version patch && npm publish --access public",
    "release": "npm run release:patch"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.7",
    "@earendil-works/pi-ai": "^0.80.7",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@lobehub/icons": "^5.6.0",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@monaco-editor/react": "^4.7.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^8.0.4",
    "jiti": "^2.7.0",
    "katex": "^0.16.47",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "next": "16.2.9",
    "pi-grok-cli": "^0.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
